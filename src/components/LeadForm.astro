---
// Lead-Formular — die Conversion. Ziel: Playbook per Mail/WhatsApp.
//
// >>> PLATZHALTER <<<
// Das finale Formular wird über ActiveCampaign eingebunden. Pascal liefert
// dazu ein Embed-Script. Ablauf beim Einbau:
//   1. AC-Formular-HTML/Script an der markierten Stelle unten einsetzen
//      ODER das native <form> unten mit dem AC-Embed ersetzen.
//   2. data-track="lead" auf das absendende Element übernehmen (Matomo-Goal
//      + Google-Ads-Conversion + Meta Pixel greifen darüber, kein GA4).
//   3. DSGVO-Consent-Checkbox beibehalten.
// Bis dahin läuft ein natives Fallback-Formular mit Erfolgs-/Fehlerzustand.
---

<div class="leadform" id="playbook">
  <div class="leadform__card">
    <p class="eyebrow">Schritt 2 von 2</p>
    <h2 class="leadform__title">Playbook kostenlos anfordern</h2>
    <p class="leadform__sub">
      Trag dich ein — wir schicken dir das Steuer-Playbook direkt per Mail oder WhatsApp zu.
    </p>

    {/* ===================================================================
        ACTIVECAMPAIGN-EMBED HIER EINSETZEN (ersetzt das <form> unten).
        =================================================================== */}

    <form
      class="leadform__form"
      id="playbook-form"
      method="post"
      action="#"
      data-track="lead"
      novalidate
    >
      {/* Honeypot statt Captcha — für Menschen unsichtbar */}
      <div class="leadform__hp" aria-hidden="true">
        <label for="company">Firma (nicht ausfüllen)</label>
        <input type="text" id="company" name="company" tabindex="-1" autocomplete="off" />
      </div>

      <div class="leadform__row">
        <label for="firstname">Vorname</label>
        <input
          type="text"
          id="firstname"
          name="firstname"
          autocomplete="given-name"
          required
          aria-describedby="firstname-err"
        />
        <span class="leadform__err" id="firstname-err" hidden>Bitte gib deinen Vornamen ein.</span>
      </div>

      <div class="leadform__row">
        <label for="email">E-Mail</label>
        <input
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          inputmode="email"
          required
          aria-describedby="email-err"
        />
        <span class="leadform__err" id="email-err" hidden>Bitte gib eine gültige E-Mail-Adresse ein.</span>
      </div>

      <div class="leadform__row">
        <label for="phone">WhatsApp / Telefon <span class="leadform__opt">(optional)</span></label>
        <input
          type="tel"
          id="phone"
          name="phone"
          autocomplete="tel"
          inputmode="tel"
        />
      </div>

      <div class="leadform__consent">
        <input type="checkbox" id="consent" name="consent" required aria-describedby="consent-err" />
        <label for="consent">
          Ich bin einverstanden, dass steine steuern FRIENDS mir das Playbook und
          weitere Infos per Mail/WhatsApp zusendet. Widerruf jederzeit möglich.
          Details in der <a href="/datenschutz">Datenschutzerklärung</a>.
        </label>
      </div>
      <span class="leadform__err" id="consent-err" hidden>Bitte bestätige die Einwilligung.</span>

      <button type="submit" class="btn btn--cta leadform__submit">
        Jetzt das Steuer-Playbook kostenlos sichern
      </button>

      <p class="leadform__note">100 % kostenlos. Kein Spam. Abmeldung jederzeit.</p>
    </form>

    <div class="leadform__success" id="playbook-success" hidden role="status">
      <p class="leadform__success-icon" aria-hidden="true">&#10003;</p>
      <h3 class="leadform__success-title">Fast geschafft!</h3>
      <p>Check dein Postfach bzw. dein WhatsApp — dein Steuer-Playbook ist unterwegs.</p>
    </div>
  </div>
</div>

<style>
  .leadform__card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    box-shadow: var(--shadow-lg);
    max-width: 520px;
    margin-inline: auto;
  }
  @media (min-width: 768px) {
    .leadform__card { padding: var(--space-12); }
  }
  .leadform__title {
    font-size: var(--text-2xl);
    margin-top: var(--space-2);
    color: var(--color-fg);
  }
  .leadform__sub {
    margin-top: var(--space-3);
    color: var(--color-fg-muted);
  }
  .leadform__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }
  .leadform__row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .leadform__row label,
  .leadform__consent label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-fg);
  }
  .leadform__opt { color: var(--color-fg-subtle); font-weight: var(--weight-regular); }
  .leadform__row input {
    min-height: 48px;
    padding: 0 var(--space-4);
    font-size: var(--text-base);
    font-family: var(--font-sans);
    color: var(--color-fg);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
  .leadform__row input:focus-visible {
    border-color: var(--color-primary);
    background: var(--color-surface);
  }
  .leadform__consent {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .leadform__consent input {
    margin-top: 3px;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    accent-color: var(--color-primary);
  }
  .leadform__consent a { color: var(--color-primary-hover); text-decoration: underline; }
  .leadform__err {
    font-size: var(--text-sm);
    color: var(--color-danger);
  }
  .leadform__submit { width: 100%; margin-top: var(--space-2); font-size: var(--text-base); }
  .leadform__note {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
    text-align: center;
  }
  /* Honeypot */
  .leadform__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  /* Erfolg */
  .leadform__success {
    text-align: center;
    padding-block: var(--space-8);
  }
  .leadform__success-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto var(--space-4);
    display: grid;
    place-items: center;
    border-radius: var(--radius-full);
    background: var(--green-100);
    color: var(--green-700);
    font-size: var(--text-2xl);
  }
  .leadform__success-title { font-size: var(--text-xl); }
  .leadform__success p { color: var(--color-fg-muted); margin-top: var(--space-2); }
</style>

<script>
  // Natives Fallback bis das ActiveCampaign-Embed eingesetzt ist.
  const form = document.getElementById("playbook-form") as HTMLFormElement | null;
  if (form) {
    const show = (id: string, on: boolean) => {
      const el = document.getElementById(id);
      if (el) el.hidden = !on;
    };
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      // Honeypot: Bots füllen es aus -> stumm abbrechen
      const hp = form.querySelector<HTMLInputElement>('input[name="company"]');
      if (hp && hp.value) return;

      const first = form.querySelector<HTMLInputElement>("#firstname")!;
      const email = form.querySelector<HTMLInputElement>("#email")!;
      const consent = form.querySelector<HTMLInputElement>("#consent")!;

      const okFirst = first.value.trim().length > 0;
      const okEmail = /.+@.+\..+/.test(email.value);
      const okConsent = consent.checked;
      show("firstname-err", !okFirst);
      show("email-err", !okEmail);
      show("consent-err", !okConsent);
      if (!okFirst || !okEmail || !okConsent) return;

      // TODO(AC): Hier POST an ActiveCampaign bzw. AC-Embed übernimmt.
      // Bis dahin: Erfolgszustand zeigen. Tracking greift über data-track="lead".
      form.hidden = true;
      show("playbook-success", true);
      document.getElementById("playbook-success")?.scrollIntoView({ block: "center" });
    });
  }
</script>
