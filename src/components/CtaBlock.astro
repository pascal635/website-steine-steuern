---
// Standard-CTA-Block — taucht unter jeder Sektion identisch auf.
// Button + Microcopy + "Weiter zu Schritt 2". Ziel immer: das Formular (#playbook).
interface Props {
  /** "light" = auf hellem Grund, "dark" = auf Ink/Grün */
  tone?: "light" | "dark";
  align?: "start" | "center";
  id?: string;
}
const { tone = "light", align = "start", id } = Astro.props;
---

<div class:list={["cta-block", `cta-block--${tone}`, `cta-block--${align}`]} id={id}>
  <a href="#playbook" class="btn btn--cta" data-track="cta">
    Jetzt das Steuer-Playbook kostenlos sichern
  </a>
  <p class="cta-block__micro">
    Wir schicken dir das Playbook direkt per Mail / WhatsApp zu.
  </p>
  <a href="#playbook" class="cta-block__link" data-track="cta">Weiter zu Schritt 2 &rarr;</a>
</div>

<style>
  .cta-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }
  .cta-block--center {
    align-items: center;
    text-align: center;
  }
  .cta-block--start {
    align-items: flex-start;
  }
  .cta-block__micro {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    max-width: 34ch;
  }
  .cta-block__link {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-primary-hover);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  /* Auf dunklem Grund */
  .cta-block--dark .cta-block__micro { color: var(--color-on-ink-muted); }
  .cta-block--dark .cta-block__link { color: var(--color-primary); }

  @media (max-width: 520px) {
    .cta-block .btn { width: 100%; }
  }
</style>
