---
// Popup-Formular (Modal). Wird von jedem CTA-Button (data-open-modal) geoeffnet.
// Genau EINE Instanz am Seitenende einbinden.
//
// >>> ACTIVECAMPAIGN-PLATZHALTER <<<
// Das finale Formular kommt von ActiveCampaign. Beim Einbau:
//   - AC-Embed/Script an der markierten Stelle einsetzen (ersetzt das native <form>).
//   - data-track="lead" auf das absendende Element uebernehmen (Matomo + Google Ads + Meta, kein GA4).
//   - Consent-Checkbox beibehalten.
// Bis dahin laeuft ein natives Fallback-Formular mit Erfolgszustand.
---
<dialog id="playbook-modal" class="modal" aria-labelledby="modal-title">
  <div class="modal__box">
    <button type="button" class="modal__close" data-close-modal aria-label="Schliessen">&times;</button>

    <h2 id="modal-title" class="modal__title">Jetzt Playbook sichern</h2>

    {/* ActiveCampaign (Konto steineundsteuern, Formular id=3) — eigenes Design,
        Post direkt an proc.php via verstecktes iframe (kein Fremd-JS beim Laden,
        Daten gehen erst beim Absenden nach Consent raus). */}
    <form
      id="playbook-form"
      class="modal__form"
      method="POST"
      action="https://steineundsteuern.activehosted.com/proc.php"
      target="ac_iframe"
      data-track="lead"
      novalidate
    >
      <input type="hidden" name="u" value="6A4BBCC4A8350" />
      <input type="hidden" name="f" value="3" />
      <input type="hidden" name="s" />
      <input type="hidden" name="c" value="0" />
      <input type="hidden" name="m" value="0" />
      <input type="hidden" name="act" value="sub" />
      <input type="hidden" name="v" value="2" />
      <input type="hidden" name="or" value="ee67667d-9abe-43c0-97c8-a65670a9554c" />

      <div class="modal__hp" aria-hidden="true">
        <label for="company">Firma (nicht ausfuellen)</label>
        <input type="text" id="company" name="company" tabindex="-1" autocomplete="off" />
      </div>

      <input type="text" id="name" name="fullname" autocomplete="name" required
             placeholder="Dein Vor- & Nachname" aria-label="Vor- und Nachname" />
      <input type="email" id="email" name="email" autocomplete="email" inputmode="email" required
             placeholder="Deine E-Mail-Adresse" aria-label="E-Mail-Adresse" />
      <input type="tel" id="phone" name="phone" autocomplete="tel" inputmode="tel"
             placeholder="Deine beste Telefonnummer (WhatsApp)" aria-label="Telefonnummer" />

      <label class="modal__consent">
        <input type="checkbox" id="consent" name="consent" required />
        <span>Ich bin einverstanden, dass steine steuern FRIENDS mir das Playbook per Mail/WhatsApp
        zusendet. Details in der <a href="/datenschutz" target="_blank">Datenschutzerklaerung</a>.</span>
      </label>
      <p class="modal__err" id="modal-err" hidden>Bitte fuelle Name, E-Mail und die Einwilligung aus.</p>

      <button type="submit" class="btn btn--cta modal__submit">
        Jetzt das Steuer-Playbook kostenlos sichern!
      </button>
      <p class="modal__micro">Wir schicken dir das Playbook direkt per Mail / WhatsApp zu.</p>
    </form>

    <div class="modal__success" id="playbook-success" hidden role="status">
      <p class="modal__success-icon" aria-hidden="true">&#10003;</p>
      <h3>Fast geschafft!</h3>
      <p>Check dein Postfach bzw. dein WhatsApp — dein Steuer-Playbook ist unterwegs.</p>
    </div>
  </div>
  {/* AC-Post landet hier (verstecktes Ziel-iframe) — keine Seitennavigation, kein CORS */}
  <iframe name="ac_iframe" title="ActiveCampaign" style="display:none" tabindex="-1" aria-hidden="true"></iframe>
</dialog>

<style>
  .modal {
    position: fixed; inset: 0; margin: 0;
    width: 100%; max-width: 100%; height: 100%; max-height: 100%;
    border: none; padding: var(--space-4); background: transparent;
    place-items: center;
  }
  .modal[open] { display: grid; }
  .modal:not([open]) { display: none; }
  .modal::backdrop { background: rgba(15,27,24,0.7); backdrop-filter: blur(2px); }
  .modal__box {
    position: relative;
    width: min(92vw, 460px);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    box-shadow: var(--shadow-lg);
  }
  @media (min-width: 768px) { .modal__box { padding: var(--space-12); } }
  .modal__close {
    position: absolute; top: var(--space-3); right: var(--space-3);
    width: 40px; height: 40px; border: none; background: none; cursor: pointer;
    font-size: 28px; line-height: 1; color: var(--color-fg-muted);
  }
  .modal__title { font-size: var(--text-2xl); text-align: center; margin-bottom: var(--space-6); }
  .modal__form { display: flex; flex-direction: column; gap: var(--space-3); }
  .modal__form input[type="text"], .modal__form input[type="email"], .modal__form input[type="tel"] {
    min-height: 52px; padding: 0 var(--space-4); font-size: var(--text-base);
    font-family: var(--font-sans); color: var(--color-fg);
    background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md);
  }
  .modal__form input:focus-visible { border-color: var(--color-primary); background: var(--color-surface); }
  .modal__consent { display: flex; gap: var(--space-3); align-items: flex-start; font-size: var(--text-xs); color: var(--color-fg-muted); }
  .modal__consent input { margin-top: 2px; width: 18px; height: 18px; flex-shrink: 0; accent-color: var(--color-primary); }
  .modal__consent a { color: var(--color-primary-hover); text-decoration: underline; }
  .modal__err { font-size: var(--text-sm); color: var(--color-danger); }
  .modal__submit { width: 100%; font-size: var(--text-base); margin-top: var(--space-2); }
  .modal__micro { font-size: var(--text-xs); color: var(--color-fg-subtle); text-align: center; }
  .modal__hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .modal__success { text-align: center; }
  .modal__success h3 { font-size: var(--text-xl); }
  .modal__success p { color: var(--color-fg-muted); margin-top: var(--space-2); }
  .modal__success-icon {
    width: 56px; height: 56px; margin: 0 auto var(--space-4); display: grid; place-items: center;
    border-radius: var(--radius-full); background: var(--green-100); color: var(--green-700); font-size: var(--text-2xl);
  }
</style>

<script>
  const dlg = document.getElementById("playbook-modal") as HTMLDialogElement | null;
  if (dlg) {
    const open = () => { if (!dlg.open) dlg.showModal(); };
    document.querySelectorAll("[data-open-modal]").forEach((b) =>
      b.addEventListener("click", open)
    );
    dlg.querySelectorAll("[data-close-modal]").forEach((b) =>
      b.addEventListener("click", () => dlg.close())
    );
    // Klick auf Backdrop schliesst
    dlg.addEventListener("click", (e) => { if (e.target === dlg) dlg.close(); });

    const form = document.getElementById("playbook-form") as HTMLFormElement | null;
    form?.addEventListener("submit", (e) => {
      const hp = form.querySelector<HTMLInputElement>('input[name="company"]');
      if (hp && hp.value) { e.preventDefault(); return; } // Bot (Honeypot)
      const name = form.querySelector<HTMLInputElement>("#name")!;
      const email = form.querySelector<HTMLInputElement>("#email")!;
      const consent = form.querySelector<HTMLInputElement>("#consent")!;
      const ok = name.value.trim() && /.+@.+\..+/.test(email.value) && consent.checked;
      const err = document.getElementById("modal-err");
      if (!ok) { e.preventDefault(); if (err) err.hidden = false; return; }
      if (err) err.hidden = true;
      // gueltig: Formular postet an ActiveCampaign (proc.php) ins verst. iframe.
      // Nicht preventDefault -> AC erhaelt die Daten. Danach Erfolgszustand zeigen.
      setTimeout(() => {
        form.hidden = true;
        const s = document.getElementById("playbook-success");
        if (s) s.hidden = false;
      }, 60);
    });
  }
</script>
