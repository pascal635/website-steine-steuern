---
// Kleines Inline-Icon-Set (stroke = currentColor), damit Nutzen-/Themen-Karten
// scharfe, leichte, markenfarbene Symbole tragen — Infografik-first statt Deko-Bild.
interface Props { name: string; }
const { name } = Astro.props;
const paths: Record<string, string> = {
  // Steuerlast runter
  "tax-down": '<path d="M6 3h12v18l-3-2-3 2-3-2-3 2z"/><path d="M9 8h6M9 12h6"/><path d="M12 15v3m0 0 2-2m-2 2-2-2"/>',
  // Abschreibung / Prozent hoch
  "chart-up": '<path d="M4 20V6M4 20h16"/><path d="M8 16l3-4 3 2 5-7"/><path d="M19 7h-3m3 0v3"/>',
  // Finanzamtsfest / Schild
  "shield-check": '<path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  // Warnung / zu viel Steuern
  "alert": '<path d="M12 3l9 16H3z"/><path d="M12 9v5M12 17h.01"/>',
  // Hebel / Regler
  "sliders": '<path d="M4 7h10M18 7h2M4 12h4M12 12h8M4 17h12M18 17h2"/><circle cx="16" cy="7" r="2"/><circle cx="10" cy="12" r="2"/><circle cx="16" cy="17" r="2"/>',
  // Schritt-für-Schritt / Prozess
  "steps": '<path d="M5 6h5M5 12h9M5 18h13"/><path d="M18 4l2 2-2 2"/>',
};
const d = paths[name] ?? "";
---
<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor"
     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
     aria-hidden="true" focusable="false" set:html={d} />
