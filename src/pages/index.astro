---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CtaCluster from "../components/CtaCluster.astro";
import LeadModal from "../components/LeadModal.astro";
import Icon from "../components/Icon.astro";

const title = "Steuer-Playbook Immobilien: bis zu 30.000 € mehr Liquidität";
const description =
  "Kostenloses Steuer-Playbook für Immobilienbesitzer: Abschreibung optimieren, Steuerlast senken, mehr Liquidität. Jetzt gratis per Mail/WhatsApp sichern.";

// Copy strikt aus dem gelieferten Doc (Jasper — Leadmagnet + LP).
const nutzen = [
  {
    icon: "tax-down",
    h: "Senke deine Steuerlast schon mit der nächsten Steuererklärung",
    t: "Du bekommst konkrete Rechnungen, Vorlagen und Schritte, die du sofort anwenden kannst — von der richtigen Kaufpreisaufteilung bis zur verkürzten Restnutzungsdauer. Kein Steuer-Studium nötig, nur ein nachvollziehbares System.",
  },
  {
    icon: "chart-up",
    h: "Verschenke keine Abschreibung mehr durch falsche Aufteilung",
    t: "Die meisten zahlen nicht zu viel Steuern, weil sie etwas falsch machen — sondern weil sie die Abschreibung nie optimiert haben. Ein zu niedriger Gebäudeanteil und pauschale 2 % AfA kosten dich Jahr für Jahr tausende Euro. Dieses Playbook zeigt dir, wie du das drehst.",
  },
  {
    icon: "shield-check",
    h: "Nutze erprobte, finanzamtsfeste Verfahren",
    t: "Jeder richtig genutzte Hebel erhöht deine Liquidität — und jeder Euro mehr Abschreibung senkt deine Steuer. Schon eine korrekte Restnutzungsdauer kann deine jährliche Abschreibung verdoppeln (4 % statt 2 % = 100 % mehr).",
  },
];

const themen = [
  {
    icon: "alert",
    h: "Warum fast jeder Immobilienbesitzer zu viel Steuern zahlt",
    t: "Die meisten kennen die drei größten Fehler nicht: eine fehlende oder defensive Kaufpreisaufteilung, eine nie geprüfte Restnutzungsdauer und Modernisierungen zum falschen Zeitpunkt. Du erfährst, warum das passiert — und was es dich konkret kostet.",
  },
  {
    icon: "sliders",
    h: "Die drei Hebel: Kaufpreisaufteilung, Restnutzungsdauer & 15-%-Grenze",
    t: "Lerne, wie du den Gebäudeanteil maximierst, deine Abschreibung von 2 % auf 4 % hebst und die gefährliche 15-%-Grenze in den ersten drei Jahren sauber umschiffst — inklusive Beispielrechnungen mit echten Zahlen.",
  },
  {
    icon: "steps",
    h: "Der finanzamtsfeste Schritt-für-Schritt-Prozess",
    t: "Du bekommst einen klaren Ablauf für Neukauf und Bestand — von der Objektauswahl über den Notartermin bis zum eingereichten Gutachten. So setzt du die Abschreibung systematisch um, statt zu raten.",
  },
];

const subline =
  "Immobilienkäufer, Eigentümer & Vermieter senken mit diesem Playbook ihre Steuerlast und gewinnen mehr Liquidität — ohne GmbH, ohne Ausland und ohne Veränderung an ihren bestehenden Objekten.";
---

<Base title={title} description={description}>
  <Header />
  <main id="top">

    <!-- ============ HERO ============ -->
    <section class="hero">
      <div class="container hero__grid">
        <div class="hero__intro">
          <span class="badge">Kostenloses Playbook von steine steuern FRIENDS</span>
          <h1 class="hero__h1">
            Nachdem du dieses Playbook gelesen hast, holst du dir im ersten Jahr
            <span class="hl">bis zu 30.000 € mehr Liquidität</span> aus deinen Immobilien.
            <em>Legal, über die richtige Abschreibung.</em>
          </h1>
          <p class="hero__sub">{subline}</p>
        </div>

        <aside class="hero__aside">
          <img
            src="/assets/images/playbook-devices-768.webp"
            srcset="/assets/images/playbook-devices-480.webp 480w, /assets/images/playbook-devices-768.webp 768w, /assets/images/playbook-devices-1200.webp 1200w"
            sizes="(min-width: 900px) 42vw, 88vw"
            width="1200"
            height="1034"
            alt="Das Steuer-Playbook 'Steuern sparen mit Abschreibung' auf Tablet und Smartphone"
            fetchpriority="high"
            decoding="async"
          />
          <CtaCluster tone="dark" align="center" />
        </aside>

        <div class="hero__nutzen">
          {nutzen.map((n) => (
            <article class="feat">
              <span class="feat__icon"><Icon name={n.icon} /></span>
              <div>
                <h2 class="feat__h">{n.h}</h2>
                <p class="feat__t">{n.t}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ FÜR WEN ============ -->
    <section class="section section--light">
      <div class="container">
        <div class="card-dark">
          <h2 class="card-dark__h">Für wen ist dieses Playbook geeignet?</h2>
          <p class="card-dark__t">
            Dieses Playbook richtet sich an Immobilienkäufer, Eigentümer, Vermieter und Investoren,
            die ihre Immobilien steuerlich endlich richtig nutzen wollen — egal ob beim nächsten Kauf
            oder im bestehenden Bestand.
          </p>
          <p class="card-dark__t">
            Besonders geeignet ist es für alle, die bereits eine oder mehrere Immobilien besitzen oder
            kaufen wollen, aber das Gefühl haben, dass sie steuerlich Geld auf dem Tisch liegen lassen.
            <strong>Nicht geeignet</strong> für Leute, die aggressive Modelle oder Grauzonen suchen —
            hier geht es um saubere, legale Optimierung.
          </p>
          <div class="card-dark__cta"><CtaCluster tone="dark" align="center" /></div>
        </div>
      </div>
    </section>

    <!-- ============ THEMEN ============ -->
    <section class="section section--cream">
      <div class="container">
        <h2 class="section__h center">Themen des Steuer-Playbooks:</h2>
        <div class="split">
          <div class="split__list">
            {themen.map((t) => (
              <article class="feat">
                <span class="feat__icon"><Icon name={t.icon} /></span>
                <div>
                  <h3 class="feat__h">{t.h}</h3>
                  <p class="feat__t">{t.t}</p>
                </div>
              </article>
            ))}
          </div>
          <aside class="split__aside">
            <img
              src="/assets/images/playbook-devices-768.webp"
              srcset="/assets/images/playbook-devices-480.webp 480w, /assets/images/playbook-devices-768.webp 768w, /assets/images/playbook-devices-1200.webp 1200w"
              sizes="(min-width: 900px) 42vw, 88vw"
              width="1200"
              height="1034"
              alt="Steuer-Playbook auf Tablet und Smartphone"
              loading="lazy"
              decoding="async"
            />
            <CtaCluster align="center" />
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ GRÜNDER ============ -->
    <section class="section founder">
      <div class="container founder__grid">
        <div class="founder__media">
          <img
            src="/assets/images/jasper-portrait.webp"
            width="720"
            height="540"
            alt="Jasper, Immobilieninvestor und Gründer von gutachten-nutzungsdauer.com"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="founder__copy">
          <h2 class="founder__h">Jasper — Immobilieninvestor & Gründer von <span class="accent">gutachten-nutzungsdauer.com</span></h2>
          <p class="founder__t">
            Jasper ist Immobilieninvestor mit Fokus auf Fix & Hold. Über 70 Einheiten gekauft, über 20
            gehandelt. Am Anfang hat er selbst große Fehler gemacht — die Kaufpreisaufteilung dem
            Steuerberater überlassen, die Restnutzungsdauer nie geprüft — und dadurch jedes Jahr
            tausende Euro verschenkt.
          </p>
          <p class="founder__t">
            Heute weiß er: Die größten Steuervorteile liegen in der richtigen Nutzung der Abschreibung.
            Weil er am Markt keine Gutachter fand, die seinen Anforderungen an Sicherheit und
            Geschwindigkeit genügten, hat er mit gutachten-nutzungsdauer.com seine eigene Lösung gebaut
            — ein Team aus zertifizierten Experten (DIN ISO IEC 17024 & DAkkS-akkreditiert), das nur ein
            Ziel hat: finanzamtsfeste Gutachten für Investoren.
          </p>
          <p class="founder__t">
            Dieses Playbook ist exakt der Prozess, durch den seine eigenen Investments laufen —
            inklusive Geld-zurück-Garantie: Wird keine Steuerersparnis herausgeholt, kostet es nichts.
          </p>
          <ul class="badges" aria-label="Zertifizierungen">
            <li>DIN ISO IEC 17024</li>
            <li>DAkkS-akkreditiert</li>
            <li>Geld-zurück-Garantie</li>
          </ul>
          <CtaCluster tone="dark" />
        </div>
      </div>
    </section>

    <!-- ============ ABSCHLUSS ============ -->
    <section class="section closer">
      <div class="container closer__inner">
        <span class="badge">Kostenloses Playbook von steine steuern FRIENDS</span>
        <h2 class="closer__h">
          Jetzt im ersten Jahr <span class="hl">bis zu 30.000 € mehr Liquidität</span> aus deinen
          Immobilien holen:
        </h2>
        <p class="closer__sub">{subline}</p>
        <img
          class="closer__img"
          src="/assets/images/playbook-devices-768.webp"
          srcset="/assets/images/playbook-devices-480.webp 480w, /assets/images/playbook-devices-768.webp 768w, /assets/images/playbook-devices-1200.webp 1200w"
          sizes="(min-width: 768px) 560px, 88vw"
          width="1200"
          height="1034"
          alt="Steuer-Playbook auf Tablet und Smartphone"
          loading="lazy"
          decoding="async"
        />
        <CtaCluster tone="dark" align="center" />
      </div>
    </section>

  </main>
  <Footer />
  <LeadModal />
</Base>

<style>
  .section--cream { background: var(--color-bg); }
  .section--light { background: var(--color-surface); }
  .section__h { font-size: var(--text-2xl); }
  @media (min-width: 768px) { .section__h { font-size: var(--text-3xl); } }
  .center { text-align: center; }

  .badge {
    display: inline-block; font-size: var(--text-sm); font-weight: var(--weight-medium);
    padding: var(--space-2) var(--space-4); border-radius: var(--radius-full);
    background: rgba(30,198,119,0.14); color: var(--color-primary); border: 1px solid rgba(30,198,119,0.3);
  }
  .hl { color: var(--color-primary); text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 4px; }
  .accent { color: var(--color-primary); font-style: normal; }

  /* ---------- Feature-/Themen-Block (Icon links, Text rechts) ---------- */
  .feat { display: grid; grid-template-columns: auto 1fr; gap: var(--space-4); padding-block: var(--space-6); border-top: 1px solid var(--color-border); }
  .feat__icon { display: inline-grid; place-items: center; width: 44px; height: 44px; border-radius: var(--radius-md); background: var(--green-50); color: var(--color-primary-hover); }
  .feat__h { font-size: var(--text-lg); margin-bottom: var(--space-2); }
  .feat__t { color: var(--color-fg-muted); font-size: var(--text-base); }

  /* ---------- HERO ---------- */
  .hero { background: var(--color-ink); color: var(--color-on-ink); padding-block: var(--space-12) var(--space-16); }
  @media (min-width: 900px) { .hero { padding-block: var(--space-16) var(--space-24); } }
  .hero__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-8); grid-template-areas: "intro" "aside" "nutzen"; }
  @media (min-width: 900px) {
    .hero__grid { grid-template-columns: 1.05fr 0.95fr; column-gap: var(--space-16); grid-template-areas: "intro aside" "nutzen aside"; align-items: start; }
  }
  .hero__intro { grid-area: intro; }
  .hero__aside { grid-area: aside; display: flex; flex-direction: column; gap: var(--space-6); }
  @media (min-width: 900px) { .hero__aside { position: sticky; top: 88px; } }
  .hero__nutzen { grid-area: nutzen; }
  .hero__h1 { font-size: clamp(1.9rem, 4.5vw, var(--text-4xl)); margin-block: var(--space-6) var(--space-4); color: var(--color-on-ink); }
  .hero__h1 em { display: block; font-size: 0.6em; color: var(--color-on-ink-muted); margin-top: var(--space-2); }
  .hero__sub { font-size: var(--text-lg); color: var(--color-on-ink-muted); max-width: 56ch; }
  .hero__aside img { width: 100%; }
  .hero .feat { border-top-color: rgba(255,255,255,0.14); }
  .hero .feat__icon { background: rgba(30,198,119,0.16); color: var(--color-primary); }
  .hero .feat__t { color: var(--color-on-ink-muted); }
  .hero .feat__h { color: var(--color-on-ink); }

  /* ---------- Dunkle Card (Für wen) ---------- */
  .card-dark { background: var(--color-ink); color: var(--color-on-ink); border-radius: var(--radius-lg); padding: var(--space-12) var(--space-8); text-align: center; }
  @media (min-width: 768px) { .card-dark { padding: var(--space-16); } }
  .card-dark__h { font-size: var(--text-2xl); margin-bottom: var(--space-6); color: var(--color-on-ink); }
  @media (min-width: 768px) { .card-dark__h { font-size: var(--text-3xl); } }
  .card-dark__t { color: var(--color-on-ink-muted); max-width: 68ch; margin: 0 auto var(--space-4); }
  .card-dark__t strong { color: var(--color-on-ink); }
  .card-dark__cta { margin-top: var(--space-8); display: flex; justify-content: center; }

  /* ---------- Split (Themen) ---------- */
  .split { display: grid; grid-template-columns: 1fr; gap: var(--space-12); margin-top: var(--space-8); }
  @media (min-width: 900px) { .split { grid-template-columns: 1.05fr 0.95fr; column-gap: var(--space-16); align-items: start; } }
  .split__aside { display: flex; flex-direction: column; gap: var(--space-6); }
  @media (min-width: 900px) { .split__aside { position: sticky; top: 88px; } }
  .split__aside img { width: 100%; }

  /* ---------- Gründer ---------- */
  .founder { background: var(--color-ink); color: var(--color-on-ink); }
  .founder__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-12); align-items: start; }
  @media (min-width: 900px) { .founder__grid { grid-template-columns: 0.8fr 1.2fr; column-gap: var(--space-16); } }
  .founder__media img { width: 100%; border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); }
  @media (min-width: 900px) { .founder__media { position: sticky; top: 88px; } }
  .founder__h { font-size: var(--text-2xl); margin-bottom: var(--space-6); color: var(--color-on-ink); }
  @media (min-width: 768px) { .founder__h { font-size: var(--text-3xl); } }
  .founder__t { color: rgba(255,255,255,0.82); margin-bottom: var(--space-4); max-width: 64ch; }
  .badges { list-style: none; display: flex; flex-wrap: wrap; gap: var(--space-3); padding: 0; margin-block: var(--space-6); }
  .badges li { font-size: var(--text-sm); font-weight: var(--weight-medium); padding: var(--space-2) var(--space-4); border-radius: var(--radius-full); border: 1px solid rgba(255,255,255,0.25); }

  /* ---------- Abschluss ---------- */
  .closer { background: var(--color-ink); color: var(--color-on-ink); text-align: center; }
  .closer__inner { display: flex; flex-direction: column; align-items: center; }
  .closer__h { font-size: var(--text-2xl); margin-block: var(--space-6) var(--space-4); color: var(--color-on-ink); max-width: 20ch; }
  @media (min-width: 768px) { .closer__h { font-size: var(--text-3xl); } }
  .closer__sub { font-size: var(--text-lg); color: var(--color-on-ink-muted); max-width: 56ch; }
  .closer__img { width: min(560px, 88%); margin-block: var(--space-12); }
</style>
