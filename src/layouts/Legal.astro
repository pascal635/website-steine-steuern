---
import "../styles/global.css";
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — steine steuern FRIENDS</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Baskervville:ital@0;1&family=Host+Grotesk:ital,wght@0,300..800;1,300..800&display=swap" />
  </head>
  <body>
    <main class="container section" style="max-width:760px">
      <p><a href="/" style="color:var(--color-primary-hover)">&larr; Zurück zur Startseite</a></p>
      <h1 style="font-size:var(--text-3xl);margin-block:var(--space-6) var(--space-4)">{title}</h1>
      <div style="background:var(--color-danger-bg);border:1px solid rgba(226,58,14,0.25);border-radius:var(--radius-md);padding:var(--space-6);color:var(--color-fg)">
        <strong>Platzhalter.</strong> Dieser Rechtstext wird vom Kunden geliefert bzw. anwaltlich
        geprüfte Inhalte werden hier eingesetzt, bevor die Seite live geht.
      </div>
      <div style="margin-top:var(--space-8)"><slot /></div>
    </main>
  </body>
</html>
